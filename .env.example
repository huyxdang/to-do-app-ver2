# TaskFlow Environment Variables Example
# Copy this file to .env and fill in the actual values

# =============================================================================
# APPLICATION
# =============================================================================
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=your-super-secret-key-change-in-production
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql+asyncpg://taskflow_user:taskflow_password@localhost:5432/taskflow_db

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# =============================================================================
# AWS GENERAL
# =============================================================================
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# =============================================================================
# AWS COGNITO
# =============================================================================
COGNITO_USER_POOL_ID=ap-southeast-1_ExamplePool
COGNITO_APP_CLIENT_ID=1example23456789abcdefghij
COGNITO_APP_CLIENT_SECRET=your-cognito-app-client-secret
COGNITO_REGION=ap-southeast-1
COGNITO_JWKS_URL=https://cognito-idp.ap-southeast-1.amazonaws.com/ap-southeast-1_ExamplePool/.well-known/jwks.json
COGNITO_DOMAIN=your-app-domain.auth.ap-southeast-1.amazoncognito.com
COGNITO_REDIRECT_URI=http://localhost:3000/auth/callback

# =============================================================================
# AWS SES (Simple Email Service)
# =============================================================================
SES_REGION=ap-southeast-1
SES_FROM_EMAIL=noreply@yourdomain.com
SES_FROM_NAME=TaskFlow
SES_VERIFICATION_EMAIL_TEMPLATE=TaskFlow-VerificationEmail
SES_PASSWORD_RESET_TEMPLATE=TaskFlow-PasswordResetEmail
SES_REMINDER_EMAIL_TEMPLATE=TaskFlow-ReminderEmail
SES_CONFIGURATION_SET=taskflow-email-tracking

# =============================================================================
# AWS S3 (Simple Storage Service)
# =============================================================================
S3_REGION=ap-southeast-1
S3_BUCKET_NAME=taskflow-user-assets
S3_AVATAR_PREFIX=avatars/
S3_PRESIGNED_URL_EXPIRE_SECONDS=3600
S3_MAX_AVATAR_SIZE_MB=5
S3_ALLOWED_AVATAR_TYPES=["image/jpeg","image/png","image/webp","image/gif"]
S3_CDN_BASE_URL=https://d1234567890example.cloudfront.net

# =============================================================================
# AWS SNS (Simple Notification Service)
# =============================================================================
SNS_REGION=ap-southeast-1
SNS_PLATFORM_APPLICATION_ARN_FCM=arn:aws:sns:ap-southeast-1:123456789012:app/GCM/TaskFlow-Android
SNS_PLATFORM_APPLICATION_ARN_APNS=arn:aws:sns:ap-southeast-1:123456789012:app/APNS/TaskFlow-iOS
SNS_PLATFORM_APPLICATION_ARN_APNS_SANDBOX=arn:aws:sns:ap-southeast-1:123456789012:app/APNS_SANDBOX/TaskFlow-iOS-Dev
SNS_NOTIFICATION_TOPIC_ARN=arn:aws:sns:ap-southeast-1:123456789012:taskflow-notifications
SNS_DEAD_LETTER_QUEUE_ARN=arn:aws:sqs:ap-southeast-1:123456789012:taskflow-notifications-dlq

# =============================================================================
# AWS SQS (Simple Queue Service)
# =============================================================================
SQS_REGION=ap-southeast-1
SQS_NOTIFICATION_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/123456789012/taskflow-notification-queue
SQS_DEAD_LETTER_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/123456789012/taskflow-notification-dlq
SQS_MESSAGE_VISIBILITY_TIMEOUT=300
SQS_MAX_RECEIVE_COUNT=3

# =============================================================================
# AWS EVENTBRIDGE SCHEDULER
# =============================================================================
EVENTBRIDGE_SCHEDULER_REGION=ap-southeast-1
EVENTBRIDGE_SCHEDULER_ROLE_ARN=arn:aws:iam::123456789012:role/TaskFlow-EventBridgeSchedulerRole
EVENTBRIDGE_SCHEDULER_TARGET_LAMBDA_ARN=arn:aws:lambda:ap-southeast-1:123456789012:function:taskflow-reminder-dispatcher
EVENTBRIDGE_SCHEDULER_GROUP_NAME=taskflow-reminders

# =============================================================================
# FCM (Firebase Cloud Messaging)
# =============================================================================
FCM_PROJECT_ID=your-firebase-project-id
FCM_SERVER_KEY=AAAA_your_fcm_server_key_here
FCM_SENDER_ID=123456789012
FCM_API_URL=https://fcm.googleapis.com/fcm/send
FCM_V1_API_URL=https://fcm.googleapis.com/v1/projects/your-firebase-project-id/messages:send
FCM_SERVICE_ACCOUNT_JSON_PATH=/app/secrets/firebase-service-account.json

# =============================================================================
# APNs (Apple Push Notification service)
# =============================================================================
APNS_KEY_ID=ABCDE12345
APNS_TEAM_ID=FGHIJ67890
APNS_BUNDLE_ID=com.yourcompany.taskflow
APNS_KEY_FILE_PATH=/app/secrets/apns-auth-key.p8
APNS_USE_SANDBOX=true
APNS_TOPIC=com.yourcompany.taskflow

# =============================================================================
# CLOUDFRONT
# =============================================================================
CLOUDFRONT_DISTRIBUTION_ID=E1234567890EXAMPLE
CLOUDFRONT_DOMAIN=d1234567890example.cloudfront.net

# =============================================================================
# PAGINATION
# =============================================================================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# =============================================================================
# TASK CONFIGURATION
# =============================================================================
TASK_OVERDUE_BATCH_INTERVAL_MINUTES=15
TASK_SOFT_DELETE_TTL_SECONDS=5
TASK_UNDO_WINDOW_HOURS=24
MAX_CATEGORIES_PER_USER=50
MAX_REMINDERS_PER_TASK=3
TASK_DESCRIPTION_MAX_LENGTH=5000
TASK_TITLE_MAX_LENGTH=255
CATEGORY_NAME_MAX_LENGTH=100

# =============================================================================
# SEARCH CONFIGURATION
# =============================================================================
SEARCH_DEBOUNCE_MS=300
SEARCH_MAX_RESULTS=50

# =============================================================================
# DASHBOARD CACHE
# =============================================================================
DASHBOARD_CACHE_TTL_SECONDS=60
DASHBOARD_UPCOMING_DAYS=7
DASHBOARD_MAX_TASKS_PER_SECTION=5

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=/var/log/taskflow/app.log